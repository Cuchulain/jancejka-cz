---
import '../styles/global.css';
import { Image, getImage } from 'astro:assets';
import avatarSrc from '../assets/images/profilovka-ctverec.png';
import ogImageSrc from '../assets/images/profilovka-obdelnik.png';
import faviconSrc from '../assets/images/favicon1.png';

const title = 'Jan Čejka';
const description = 'Šaman, léčitel a vývojář. Vyberte svou cestu.';
const canonicalURL = 'https://jancejka.cz';

const processedOgImage = await getImage({
  src: ogImageSrc,
  width: 1200,
  height: 630,
  format: 'jpeg',
});

const faviconIcon32  = await getImage({ src: faviconSrc, width: 32,  height: 32,  format: 'png' });
const appleTouchIcon = await getImage({ src: faviconSrc, width: 180, height: 180, format: 'png' });

const ogImage = `${canonicalURL}${processedOgImage.src}`;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicon -->
    <link rel="icon" href={faviconIcon32.src} type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href={appleTouchIcon.src} sizes="180x180" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jan Čejka" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Jan Čejka" />
    <meta property="og:locale" content="cs_CZ" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = sessionStorage.getItem('theme');
        let isDark;
        if (stored) {
          isDark = stored === 'dark';
        } else {
          const prefersDark  = window.matchMedia('(prefers-color-scheme: dark)').matches;
          const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          const h = new Date().getHours();
          isDark = prefersDark || (!prefersLight && (h < 6 || h >= 22));
        }
        if (isDark) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>

  <body class="min-h-screen bg-stone-50 dark:bg-stone-950 text-stone-900 dark:text-stone-100 transition-colors duration-300">

    <!-- Theme toggle -->
    <div class="absolute top-5 right-5">
      <button
        id="theme-toggle"
        aria-label="Přepnout světlý/tmavý režim"
        class="w-9 h-9 rounded-full flex items-center justify-center text-stone-500 dark:text-stone-400 hover:bg-stone-200 dark:hover:bg-stone-800 transition-colors"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>

    <main class="flex flex-col items-center justify-center min-h-screen px-6 py-16">

      <!-- Hero -->
      <div class="text-center mb-16">
        <div class="mb-6 mx-auto w-24 h-24 rounded-full overflow-hidden ring-2 ring-ritual/30 shadow-md">
          <Image
            src={avatarSrc}
            alt="Jan Čejka"
            width={256}
            height={256}
            class="w-full h-full object-cover"
          />
        </div>
        <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-3">
          Jan Čejka
        </h1>
        <p class="text-stone-500 dark:text-stone-400 text-lg tracking-widest uppercase text-sm">
          šaman &middot; léčitel &middot; vývojář
        </p>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full max-w-2xl">

        <!-- Šamanismus & Léčení -->
        <a
          href="https://saman.jancejka.cz"
          class="group relative flex flex-col rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
        >
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"
            style="background: radial-gradient(circle at top left, oklch(from #c2813a l c h / 0.08), transparent 70%)">
          </div>
          <div class="mb-5 w-12 h-12 rounded-xl flex items-center justify-center bg-ritual/10 text-ritual">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="M7 9.5C8 7 10 6 12 6s4 1 5 3.5c.5 1.5.5 3-.5 4.5C15 16 13.5 17 12 17s-3-1-4.5-3c-1-1.5-1-3-.5-4.5z"/>
              <path d="M12 6v2m0 9v2M6 12H4m16 0h-2"/>
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-2 group-hover:text-ritual transition-colors">
            Šamanismus & Léčení
          </h2>
          <p class="text-stone-500 dark:text-stone-400 text-sm leading-relaxed flex-1">
            Duchovní průvodcovství, energetické léčení a šamanská praxe. Propojení prastaré moudrosti se současným životem.
          </p>
          <div class="mt-6 flex items-center gap-1 text-ritual text-sm font-medium">
            <span>Navštívit</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>

        <!-- Vývoj & Portfolio -->
        <a
          href="https://dev.jancejka.cz"
          class="group relative flex flex-col rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden"
        >
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl"
            style="background: radial-gradient(circle at top left, oklch(from #7055a8 l c h / 0.08), transparent 70%)">
          </div>
          <div class="mb-5 w-12 h-12 rounded-xl flex items-center justify-center bg-mystic/10 text-mystic">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h2 class="text-xl font-semibold mb-2 group-hover:text-mystic transition-colors">
            Vývoj & Portfolio
          </h2>
          <p class="text-stone-500 dark:text-stone-400 text-sm leading-relaxed flex-1">
            Softwarový vývoj, projekty a technické portfolio. Moderní webové aplikace a systémová integrace.
          </p>
          <div class="mt-6 flex items-center gap-1 text-mystic text-sm font-medium">
            <span>Navštívit</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>

      </div>
    </main>

    <!-- Footer -->
    <footer class="py-8 text-center text-stone-400 dark:text-stone-600 text-xs">
      &copy; {new Date().getFullYear()} Jan Čejka
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        sessionStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>

  </body>
</html>
